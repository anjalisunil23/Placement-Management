# Local development overrides (optional — loaded after .env)
# Copy to .env.local and set your local MySQL password.

APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pms_db
DB_USERNAME=root
DB_PASSWORD=

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# AWS S3 (campus Lambda)
AWS_S3_API_ENDPOINT=https://hep6ztvxpjewibbu6z57hmfijm0czbnu.lambda-url.ap-south-1.on.aws
AWS_S3_PREFIX=ajce-placements
AWS_S3_DOCS_ROOT=Docs
AWS_S3_PHYSICAL_BUCKET=iqac-docs
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_TIMEOUT=60
