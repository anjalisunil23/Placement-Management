APP_NAME="Placement Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://placements.amaljyothi.ac.in

# MariaDB (cPanel — MySQL Databases)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=placementsajce_db
DB_USERNAME=placementsajce_root
DB_PASSWORD=your_db_password

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=86400
SESSION_LIFETIME=7200

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@your-domain.com
MAIL_FROM_NAME="PMS Portal"

# WhatsApp (AES WAPI) — placement update templates
WHATSAPP_ENABLED=true
WHATSAPP_ENDPOINT=https://wapi.aesajce.in/send
WHATSAPP_TAG="AJCE Placements"
WHATSAPP_TEMPLATE=ajce_official_notification
WHATSAPP_SIGNATURE="AJCE Placement Cell"

MAX_RESUME_SIZE=5242880
MAX_JD_SIZE=10485760

CORS_ALLOWED_ORIGINS=https://placements.amaljyothi.ac.in

# Super-admin AES / portal logins (comma-separated)
SUPER_ADMIN_EMAILS=placements@amaljyothi.ac.in
