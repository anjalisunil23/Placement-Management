APP_NAME="Placement Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

# MongoDB Atlas (recommended on shared hosting)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=pms_db

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=86400
SESSION_LIFETIME=7200

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@your-domain.com
MAIL_FROM_NAME="PMS Portal"

MAX_RESUME_SIZE=5242880
MAX_JD_SIZE=10485760

# Your live site URL (no trailing slash)
CORS_ALLOWED_ORIGINS=https://your-domain.com
