<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Favicon (browsers request /favicon.ico by default)
RewriteRule ^favicon\.ico$ favicon.svg [L]

# Avoid Apache content-negotiation breaking extensionless HTML routes
Options -MultiViews

DirectoryIndex index.php public-stats.html index.html

# API → PHP router
RewriteRule ^backend/api(?:/index\.php)?(/.*)?$ backend/api/index.php [L,QSA]
RewriteRule ^api(?:/index\.php)?(/.*)?$ backend/api/index.php [L,QSA]

# AES login debug — dump POST body
RewriteRule ^dologin/?$ dologin.php [L,QSA]

# Root → public landing page
RewriteRule ^$ public-stats.html [L]

# Legacy public stats URLs (production)
RewriteRule ^public/stats\.html$ public-stats.html [L]
RewriteRule ^public_stats\.html$ public-stats.html [L]

# Extensionless HTML: /dashboard → dashboard.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Always fetch latest JS/CSS (avoid stale sidebar, nav, and drive fixes on production)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
</IfModule>
