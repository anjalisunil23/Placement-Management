APP_NAME="Placement Management System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# MariaDB / MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pms_db
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRY=86400

# Session
SESSION_LIFETIME=7200

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@college.edu
MAIL_FROM_NAME="PMS Portal"

# Upload limits (bytes)
MAX_RESUME_SIZE=5242880
MAX_JD_SIZE=10485760

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
