APP_NAME="Placement Management System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# MariaDB / MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pms_db
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRY=86400

# Session
SESSION_LIFETIME=7200

# Email — ElasticEmail (primary) or SMTP
MAIL_DRIVER=elasticemail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=info@aessas.org
MAIL_FROM_NAME="Placement Cell - Amal Jyothi"
ELASTICEMAIL_API_KEY=
ELASTICEMAIL_ENDPOINT=https://api.elasticemail.com/v2/email/send

# WhatsApp (AES WAPI) — placement update templates
WHATSAPP_ENABLED=true
WHATSAPP_ENDPOINT=https://wapi.aesajce.in/send
WHATSAPP_TAG="AJCE Placements"
WHATSAPP_TEMPLATE=ajce_official_notification
WHATSAPP_SIGNATURE="AJCE Placement Cell"

# Upload limits (bytes)
MAX_RESUME_SIZE=5242880
MAX_JD_SIZE=10485760

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Super-admin AES / portal logins (comma-separated)
SUPER_ADMIN_EMAILS=placements@amaljyothi.ac.in

# AES institute API (api.aesajce.in)
AES_AUTH_KEY=
AES_REF_HOST=placements.amaljyothi.ac.in
AES_API_URL=https://api.aesajce.in/
AES_API_ORIGIN=https://www.aesajce.in
AES_API_REFERER=https://www.aesajce.in/
