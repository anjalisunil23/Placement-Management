{
    "name": "pms/placement-management-system",
    "description": "College Placement Management Portal",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "mongodb/mongodb": "^2.3",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "tecnickcom/tcpdf": "^6.7",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "PMS\\": "backend/"
        },
        "classmap": [
            "backend/admin",
            "backend/alumni",
            "backend/api",
            "backend/auth",
            "backend/company",
            "backend/config",
            "backend/middleware",
            "backend/models",
            "backend/officer",
            "backend/schemas",
            "backend/services",
            "backend/staff",
            "backend/student",
            "backend/utils"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "block-insecure": false
        }
    }
}
