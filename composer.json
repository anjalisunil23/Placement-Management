{
    "name": "pms/placement-management-system",
    "description": "College Placement Management Portal",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "tecnickcom/tcpdf": "^6.7",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "PMS\\Utils\\": "backend/utils/",
            "PMS\\Services\\": "backend/services/",
            "PMS\\Models\\": "backend/models/",
            "PMS\\Middleware\\": "backend/middleware/",
            "PMS\\Schemas\\": "backend/schemas/",
            "PMS\\Database\\": "backend/database/",
            "PMS\\Admin\\": "backend/admin/",
            "PMS\\Officer\\": "backend/officer/",
            "PMS\\Staff\\": "backend/staff/",
            "PMS\\Student\\": "backend/student/",
            "PMS\\Alumni\\": "backend/alumni/",
            "PMS\\Api\\": "backend/api/",
            "PMS\\Auth\\": "backend/auth/",
            "PMS\\Company\\": "backend/company/",
            "PMS\\": "backend/"
        },
        "classmap": [
            "backend/admin",
            "backend/alumni",
            "backend/api",
            "backend/auth",
            "backend/company",
            "backend/config",
            "backend/database",
            "backend/middleware",
            "backend/models",
            "backend/officer",
            "backend/schemas",
            "backend/services",
            "backend/staff",
            "backend/student",
            "backend/utils"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "block-insecure": false
        }
    }
}
